# Web3Auth Configuration
# Get your Client ID from https://dashboard.web3auth.io
WEB3AUTH_CLIENT_ID=

# Network: sapphire_devnet (development) or sapphire_mainnet (production)
WEB3AUTH_NETWORK=sapphire_devnet

# WalletConnect / Reown Configuration
# Get your Project ID from https://cloud.reown.com (formerly cloud.walletconnect.com)
WALLETCONNECT_PROJECT_ID=

# Backend Configuration
# Use your computer's LAN IP when testing on a physical phone.
BACKEND_URL=http://192.168.1.2:3000
# Optional. If omitted, websocket URL is derived from BACKEND_URL.
BACKEND_WS_URL=ws://192.168.1.2:3000
